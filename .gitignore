# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/

# ─── Next.js ──────────────────────────────────────────────────────────────────
# Build cache and output — regenerated on every build
.next/
# Static export output (next export)
out/

# ─── Environment variables ────────────────────────────────────────────────────
# Never commit secrets
.env
.env.*
# DO commit the example template (no real secrets inside)
!.env.example

# ─── TypeScript ───────────────────────────────────────────────────────────────
# Incremental compilation cache
*.tsbuildinfo

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
pnpm-debug.log*

# ─── npm ──────────────────────────────────────────────────────────────────────
.npm

# ─── Linter / formatter caches ────────────────────────────────────────────────
.eslintcache
.prettiercache
.stylelintcache

# ─── Test output ──────────────────────────────────────────────────────────────
# Vitest coverage reports
coverage/
# Istanbul/nyc coverage
.nyc_output/
# Playwright raw test results
test-results/
# Playwright HTML report
playwright-report/
# Playwright browser binaries cache
playwright/.cache/

# ─── OS files ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ─── IDE ──────────────────────────────────────────────────────────────────────
.idea/
*.swp
*.swo
.vercel
.env*
